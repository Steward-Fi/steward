# Steward deployment configuration
# Copy to .env and fill in values

# Required — vault master encryption password
STEWARD_MASTER_PASSWORD=

# Database — leave empty to use local PostgreSQL container
# For Neon: postgresql://user:pass@ep-xxx.neon.tech/steward?sslmode=require
DATABASE_URL=

# Required when using the bundled Postgres container — password for the managed
# Postgres instance. There is NO insecure default; the compose file fails to
# start if this is unset. Also referenced by the default DATABASE_URL above.
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Redis — for rate limiting, spend tracking, policy caching
REDIS_URL=redis://localhost:6379

# EVM configuration
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Solana configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Platform admin key — auto-generated if empty
STEWARD_PLATFORM_KEY=
