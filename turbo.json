{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "FAKE_OAUTH_PORT",
    "MILADY_SKIP_STEWARD_FI_LIVE_SMOKE",
    "PLATFORM_KEY",
    "PROXY_URL",
    "SKIP_PROXY_E2E",
    "STEWARD_ALLOW_INSECURE_DB",
    "STEWARD_AUDIT_HMAC_KEY",
    "STEWARD_BEHIND_PROXY",
    "STEWARD_BIND_HOST",
    "STEWARD_JWT_SECRET",
    "STEWARD_KDF_SALT",
    "STEWARD_MASTER_PASSWORD",
    "STEWARD_PLATFORM_KEY",
    "STEWARD_PLATFORM_KEYS",
    "STEWARD_SESSION_SECRET",
    "STEWARD_SOC2_ALLOW_DEPENDENCY_SKIP",
    "STEWARD_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "@stwd/agent-trader#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/api#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/auth#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/db#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/example-waifu-integration#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/policy-engine#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/proxy#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/vault#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/webhooks#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "cache": false
    }
  }
}
