# Required for the API container.
STEWARD_MASTER_PASSWORD=replace-with-a-long-random-secret

# Required unless you use the default Compose Postgres service.
# For Compose defaults this resolves to:
# postgresql://steward:steward_dev_password@postgres:5432/steward
DATABASE_URL=postgresql://steward:steward_dev_password@postgres:5432/steward

# Optional API settings.
PORT=3200
API_VERSION=0.1.0
RPC_URL=https://mainnet.base.org
STEWARD_DEFAULT_TENANT_KEY=

# Optional Compose Postgres settings.
POSTGRES_DB=steward
POSTGRES_USER=steward
POSTGRES_PASSWORD=steward_dev_password
