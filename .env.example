# ─── API ───────────────────────────────────────────────────────────────────────
PORT=3200
API_VERSION=0.1.0

# ─── Database ──────────────────────────────────────────────────────────────────
# When using docker compose, the default matches the Postgres service below.
DATABASE_URL=postgresql://steward:steward_dev_password@postgres:5432/steward

# Optional: override individual Postgres service settings
# POSTGRES_DB=steward
# POSTGRES_USER=steward
# POSTGRES_PASSWORD=steward_dev_password

# ─── Vault ─────────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
STEWARD_MASTER_PASSWORD=your-256-bit-hex-secret

# ─── JWT ───────────────────────────────────────────────────────────────────────
# RECOMMENDED for production: separate JWT signing secret from master password
# Generate with: openssl rand -hex 32
# If not set, falls back to STEWARD_MASTER_PASSWORD (with warning)
# STEWARD_JWT_SECRET=your-jwt-signing-secret

# ─── Chain ─────────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ─── Auth ──────────────────────────────────────────────────────────────────────
# API key for the default tenant (local dev only — use real tenant management in production)
STEWARD_DEFAULT_TENANT_KEY=local-api-key

# ─── Web / Dashboard ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STEWARD_API_URL=http://localhost:3200
NEXT_PUBLIC_STEWARD_API_KEY=local-api-key
NEXT_PUBLIC_STEWARD_TENANT_ID=default
