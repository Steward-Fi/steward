{
  "name": "@stwd/db",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pglite": "./src/pglite-entry.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --watch",
    "migrate": "bun src/migrate.ts",
    "migrate:neon": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "test": "bun test"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@neondatabase/serverless": "^0.10.4",
    "@stwd/shared": "workspace:*",
    "drizzle-orm": "^0.44.5",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.4"
  },
  "description": "Drizzle ORM schema, migrations, and PostgreSQL client for Steward"
}
