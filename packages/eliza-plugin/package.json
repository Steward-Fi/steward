{
  "name": "@stwd/eliza-plugin",
  "version": "0.1.0",
  "description": "Steward wallet management plugin for ElizaOS agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@stwd/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@elizaos/core": ">=2.0.0-alpha.50"
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-alpha.77",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  }
}
